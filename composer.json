{
    "name": "kariricode/processor-pipeline",
    "description": "A robust, immutable processor pipeline component for the KaririCode Framework — ARFA 1.3 compliant. Enables modular, configurable processing chains for data transformation, validation, and sanitization.",
    "keywords": [
        "php",
        "pipeline",
        "processor",
        "framework",
        "processor-architecture",
        "kariri-code",
        "arfa",
        "immutable",
        "reactive-flow",
        "php84"
    ],
    "homepage": "https://kariricode.org",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Walmir Silva",
            "email": "community@kariricode.org"
        }
    ],
    "require": {
        "php": "^8.4",
        "kariricode/contract": "^2.8",
        "kariricode/exception": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "KaririCode\\ProcessorPipeline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KaririCode\\ProcessorPipeline\\Tests\\": "tests/"
        }
    },
    "require-dev": {},
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "support": {
        "issues": "https://github.com/KaririCode-Framework/kariricode-processor-pipeline/issues",
        "source": "https://github.com/KaririCode-Framework/kariricode-processor-pipeline"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
